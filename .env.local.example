# Auth
ADMIN_PASSWORD_HASH=$2a$10$example_bcrypt_hash_here
SESSION_SECRET=your_32_character_random_secret_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agent Webhook
AGENT_SHARED_SECRET=your_webhook_secret

# Composio — Google Workspace integration
# Get your API key at https://app.composio.dev/settings
COMPOSIO_API_KEY=your_composio_api_key_here
# Optional: the entity ID for the connected Google account.
# Found in Composio dashboard → Connected Accounts → copy the Entity ID.
# If unset, Composio uses the default connected account.
COMPOSIO_ENTITY_ID=
